# Database: set this to your Supabase Postgres connection string in production.
DATABASE_URL=postgresql://postgres:password@localhost:5432/cfautobooks
SECRET_KEY=replace-with-a-long-random-secret
ADMIN_API_TOKEN=replace-with-an-admin-only-token

# Racing form provider. Keep real keys in environment variables, never in source.
RACING_FORM_PROVIDER=generic_http
RACING_FORM_API_BASE_URL=https://provider.example.com
RACING_FORM_API_KEY=replace-with-racing-form-api-key
RACING_FORM_API_KEY_HEADER=Authorization
RACING_FORM_MEETINGS_PATH=/racecards
RACING_FORM_RACECARD_PATH=/racecards/{meeting_id}
RACING_FORM_RESULTS_PATH=/results

# Odds provider.
ODDS_PROVIDER=generic_http
ODDS_API_BASE_URL=https://odds-provider.example.com
ODDS_API_KEY=replace-with-odds-api-key
ODDS_API_KEY_HEADER=Authorization
ODDS_MARKETS_PATH=/odds

STRIPE_API_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
